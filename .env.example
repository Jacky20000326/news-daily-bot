# .env.example

# ─── AI ───────────────────────────────────────
GEMINI_API_KEY=AIza...              # Google AI Studio 取得：https://aistudio.google.com/apikey
AI_MODEL=gemini-1.5-flash           # 可選：gemini-1.5-pro / gemini-2.0-flash

# ─── 新聞來源 ─────────────────────────────────
NEWSAPI_KEY=...

# ─── Email（SMTP）────────────────────────────
SENDER_EMAIL=noreply@yourdomain.com
EMAIL_RECIPIENTS=user1@example.com,user2@example.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=app-specific-password

# ─── Gmail 白名單（完整報告）──────────────────
GMAIL_WHITELIST=user1@gmail.com,user2@gmail.com  # 這些地址會收到完整報告內容，方便 Gmail 搜尋

# ─── 警報 ────────────────────────────────────
ALERT_EMAIL=admin@yourdomain.com

# ─── 排程 ────────────────────────────────────
TIMEZONE=Asia/Taipei
REPORT_HOUR=9                       # 報告發送時間（小時）

# ─── 功能開關 ────────────────────────────────
ENABLE_RSS=true
ENABLE_COINGECKO=true
ENABLE_COINDESK=true                # 設 false 停用 CoinDesk Data API 來源
ENABLE_MESSARI=true                 # 設 false 停用 Messari News API 來源
MESSARI_API_KEY=                    # Messari API Key（https://messari.io/account/api 取得）
DRY_RUN=false                       # true = 產出報告但不寄信（本地測試用）

# ─── 日誌 ────────────────────────────────────
# ─── 線上 HTML 報告 / GitHub Pages（選填）───────────────────────────
GITHUB_TOKEN=ghp_...                # GitHub PAT（需有目標 repo 的 contents 寫入權限）
GITHUB_OWNER=your-github-username   # GitHub 帳號名稱
GITHUB_REPO=crypto-daily-pages      # 已啟用 GitHub Pages 的 repo 名稱

LOG_LEVEL=info                      # debug / info / warn / error
