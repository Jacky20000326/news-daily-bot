<!DOCTYPE html>
<html lang="zh-Hant">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta http-equiv="X-UA-Compatible" content="IE=edge" />
  <title>加密貨幣日報 {{reportDate}} — AI 深度分析</title>
  <!--[if !mso]><!-->
  <style>
    /* Web-only enhancements — email clients will strip this block */
    body { -webkit-font-smoothing: antialiased; }
    .story-card:hover { border-color: #3a3a5e !important; }
    .read-link:hover { text-decoration: underline !important; }
    @media (max-width: 600px) {
      .main-table { width: 100% !important; }
      .header-title { font-size: 24px !important; }
      .story-title-text { font-size: 17px !important; }
      .card-inner { padding: 20px !important; }
      .stat-cell { padding: 0 12px !important; }
    }
  </style>
  <!--<![endif]-->
</head>
<body style="margin:0;padding:0;background-color:#0f0f1a;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI','Noto Sans TC',sans-serif;color:#e0e0e0;line-height:1.8;-webkit-text-size-adjust:100%;-ms-text-size-adjust:100%;">

  <!-- 外層容器 -->
  <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%" style="background-color:#0f0f1a;">
    <tr>
      <td align="center">

        <!-- ═══════════════════════════════════════
             HEADER
        ═══════════════════════════════════════ -->
        <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%" style="background-color:#1a1a2e;border-bottom:3px solid #f39c12;">
          <tr>
            <td align="center" style="padding:48px 24px 40px 24px;">
              <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="820" class="main-table" style="max-width:820px;width:100%;">
                <tr>
                  <td align="center">
                    <p style="margin:0 0 8px 0;font-size:11px;letter-spacing:4px;text-transform:uppercase;color:#7f8fa6;font-weight:600;">DAILY CRYPTO INTELLIGENCE</p>
                    <h1 class="header-title" style="margin:0;font-size:32px;font-weight:800;color:#ffffff;letter-spacing:-0.5px;">加密貨幣日報</h1>
                    <p style="margin:8px 0 0 0;font-size:18px;color:#a8d8ea;">{{reportDate}}</p>
                    <p style="margin:12px 0 0 0;font-size:12px;color:#7f8fa6;">資料時間：{{timeWindowFrom}} ～ {{timeWindowTo}}（台北時間 UTC+8）</p>

                    <!-- 統計數據 -->
                    <table role="presentation" cellpadding="0" cellspacing="0" border="0" style="margin:20px auto 0 auto;">
                      <tr>
                        <td class="stat-cell" align="center" style="padding:0 20px;">
                          <p style="margin:0;font-size:24px;font-weight:700;color:#f39c12;">{{totalCollected}}</p>
                          <p style="margin:0;font-size:11px;color:#7f8fa6;">收集新聞</p>
                        </td>
                        <td class="stat-cell" align="center" style="padding:0 20px;">
                          <p style="margin:0;font-size:24px;font-weight:700;color:#f39c12;">{{selectedCount}}</p>
                          <p style="margin:0;font-size:11px;color:#7f8fa6;">精選報導</p>
                        </td>
                        <td class="stat-cell" align="center" style="padding:0 20px;">
                          <p style="margin:0;font-size:24px;font-weight:700;color:#f39c12;">{{deepCount}}</p>
                          <p style="margin:0;font-size:11px;color:#7f8fa6;">深度分析</p>
                        </td>
                      </tr>
                    </table>
                  </td>
                </tr>
              </table>
            </td>
          </tr>
        </table>

        <!-- ═══════════════════════════════════════
             內容區域
        ═══════════════════════════════════════ -->
        <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="820" class="main-table" style="max-width:820px;width:100%;">
          <tr>
            <td style="padding:0 24px;">

              <!-- ═══ 今日市場總覽 ═══ -->
              <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%" style="margin:40px 0;">
                <tr>
                  <td style="background-color:#1c2541;border-left:4px solid #3498db;border-radius:0 12px 12px 0;padding:32px 36px;">
                    <p style="margin:0 0 12px 0;font-size:11px;font-weight:700;color:#3498db;letter-spacing:2px;text-transform:uppercase;">今日市場總覽</p>
                    <p style="margin:0;font-size:16px;line-height:2;color:#d0d0d0;">{{executiveSummary}}</p>
                  </td>
                </tr>
              </table>

              <!-- ═══ 區塊標題：重點新聞深度分析 ═══ -->
              <table role="presentation" cellpadding="0" cellspacing="0" border="0" style="margin:48px 0 24px 0;">
                <tr>
                  <td style="width:4px;min-width:4px;background-color:#e74c3c;border-radius:2px;">&nbsp;</td>
                  <td style="padding-left:12px;">
                    <h2 style="margin:0;font-size:22px;font-weight:700;color:#ffffff;display:inline;">重點新聞深度分析</h2>
                    <span style="font-size:13px;color:#7f8fa6;margin-left:8px;">Top {{deepCount}}</span>
                  </td>
                </tr>
              </table>

              <!-- ═══ 深度分析新聞卡片 ═══ -->
              {{#each deepStories}}
              <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%" class="story-card"
                     id="story-{{id}}"
                     style="background-color:#1c1c2e;border:1px solid #2a2a3e;border-radius:12px;margin-bottom:24px;">
                <tr>
                  <td class="card-inner" style="padding:32px;">

                    <!-- 排名圓圈 + 標題 -->
                    <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%" style="margin-bottom:16px;">
                      <tr>
                        <td style="width:48px;vertical-align:top;padding-right:16px;">
                          <table role="presentation" cellpadding="0" cellspacing="0" border="0">
                            <tr>
                              <td align="center" style="width:40px;height:40px;border-radius:50%;font-size:16px;font-weight:800;color:#ffffff;
                                {{#if (gte importanceScore 9)}}background-color:#e74c3c;{{/if}}
                                {{#if (and (gte importanceScore 7) (lte importanceScore 8))}}background-color:#e67e22;{{/if}}
                                {{#if (lt importanceScore 7)}}background-color:#3498db;{{/if}}
                              ">{{index_1 @index}}</td>
                            </tr>
                          </table>
                        </td>
                        <td style="vertical-align:top;">
                          <h3 class="story-title-text" style="margin:0;font-size:20px;font-weight:700;color:#ffffff;line-height:1.5;">{{title}}</h3>
                        </td>
                      </tr>
                    </table>

                    <!-- Badge 列 -->
                    <table role="presentation" cellpadding="0" cellspacing="0" border="0" style="margin-bottom:20px;">
                      <tr>
                        <!-- 重要度 -->
                        <td style="padding-right:8px;padding-bottom:6px;">
                          <span style="display:inline-block;padding:3px 10px;border-radius:20px;font-size:11px;font-weight:600;background-color:#3d2e0a;color:#f39c12;">&#9733; 重要度 {{importanceScore}}/10</span>
                        </td>
                        <!-- 分類 -->
                        <td style="padding-right:8px;padding-bottom:6px;">
                          <span style="display:inline-block;padding:3px 10px;border-radius:20px;font-size:11px;font-weight:600;background-color:#1a2a3d;color:#5dade2;">
                            {{#if (eq category 'market')}}市場行情{{/if}}
                            {{#if (eq category 'regulation')}}監管政策{{/if}}
                            {{#if (eq category 'technology')}}技術發展{{/if}}
                            {{#if (eq category 'defi')}}DeFi{{/if}}
                            {{#if (eq category 'nft')}}NFT{{/if}}
                            {{#if (eq category 'security')}}安全事件{{/if}}
                            {{#if (eq category 'macro')}}總體經濟{{/if}}
                            {{#if (eq category 'exchange')}}交易所動態{{/if}}
                            {{#if (eq category 'other')}}其他{{/if}}
                          </span>
                        </td>
                        <!-- 情緒 -->
                        <td style="padding-right:8px;padding-bottom:6px;">
                          <span style="display:inline-block;padding:3px 10px;border-radius:20px;font-size:11px;font-weight:600;
                            {{#if (eq sentiment 'positive')}}background-color:#0e2e1a;color:#2ecc71;{{/if}}
                            {{#if (eq sentiment 'negative')}}background-color:#2e0e0e;color:#e74c3c;{{/if}}
                            {{#if (eq sentiment 'neutral')}}background-color:#1e1e1e;color:#95a5a6;{{/if}}
                          ">
                            {{#if (eq sentiment 'positive')}}&#8679; 正向{{/if}}
                            {{#if (eq sentiment 'negative')}}&#8681; 負向{{/if}}
                            {{#if (eq sentiment 'neutral')}}&#8644; 中性{{/if}}
                          </span>
                        </td>
                        <!-- 相關代幣 -->
                        {{#each relatedTickers}}
                        <td style="padding-right:8px;padding-bottom:6px;">
                          <span style="display:inline-block;padding:3px 10px;border-radius:20px;font-size:11px;font-weight:600;background-color:#1e1530;color:#bb8fce;">{{this}}</span>
                        </td>
                        {{/each}}
                      </tr>
                    </table>

                    <!-- AI 分析重點 -->
                    {{#if aiSummary}}
                    <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%" style="margin-bottom:16px;">
                      <tr>
                        <td style="background-color:#12121e;border-left:3px solid #e74c3c;border-radius:0 8px 8px 0;padding:24px 28px;">
                          <p style="margin:0 0 10px 0;font-size:10px;font-weight:700;color:#e74c3c;letter-spacing:1.5px;text-transform:uppercase;">AI 分析重點</p>
                          <p style="margin:0;font-size:15px;line-height:2;color:#c8c8c8;">{{aiSummary}}</p>
                        </td>
                      </tr>
                    </table>
                    {{/if}}

                    <!-- AI 深度分析報告 -->
                    {{#if deepAnalysis}}
                    <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%" style="margin:16px 0;">
                      <tr>
                        <td style="background-color:#0d1117;border:1px solid #30363d;border-left:4px solid #f39c12;border-radius:0 12px 12px 0;padding:28px 32px;">
                          <p style="margin:0 0 16px 0;font-size:11px;font-weight:700;color:#f39c12;letter-spacing:2px;text-transform:uppercase;padding-bottom:8px;border-bottom:1px solid #21262d;">AI 深度分析報告（基於原文）</p>
                          <div style="font-size:15px;line-height:2;color:#c9d1d9;white-space:pre-line;">{{{deepAnalysis}}}</div>
                        </td>
                      </tr>
                    </table>
                    {{/if}}

                    <!-- 來源 + 閱讀原文 -->
                    <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%" style="margin-top:16px;border-collapse:collapse;">
                      <tr>
                        <td style="padding-top:16px;border-top:1px solid #2a2a3e;font-size:12px;color:#7f8fa6;">
                          <strong style="color:#95a5a6;">{{sourceName}}</strong>
                          <span style="margin:0 6px;color:#3d3d5e;">&#183;</span>
                          <span>{{publishedAtFormatted}}（台北時間）</span>
                        </td>
                        <td align="right" style="padding-top:16px;border-top:1px solid #2a2a3e;">
                          <a href="{{url}}" target="_blank" rel="noopener noreferrer" class="read-link"
                             style="font-size:12px;color:#3498db;text-decoration:none;font-weight:600;">閱讀原文 &rarr;</a>
                        </td>
                      </tr>
                    </table>

                  </td>
                </tr>
              </table>
              {{/each}}

              <!-- ═══ 其他重要新聞 ═══ -->
              {{#if briefStories.length}}
              <table role="presentation" cellpadding="0" cellspacing="0" border="0" style="margin:48px 0 24px 0;">
                <tr>
                  <td style="width:4px;min-width:4px;background-color:#3498db;border-radius:2px;">&nbsp;</td>
                  <td style="padding-left:12px;">
                    <h2 style="margin:0;font-size:22px;font-weight:700;color:#ffffff;">其他重要新聞</h2>
                  </td>
                </tr>
              </table>

              {{#each briefStories}}
              <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%" class="story-card"
                     id="story-{{id}}"
                     style="background-color:#1c1c2e;border:1px solid #2a2a3e;border-radius:12px;margin-bottom:24px;">
                <tr>
                  <td class="card-inner" style="padding:32px;">

                    <!-- 排名圓圈 + 標題 -->
                    <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%" style="margin-bottom:16px;">
                      <tr>
                        <td style="width:48px;vertical-align:top;padding-right:16px;">
                          <table role="presentation" cellpadding="0" cellspacing="0" border="0">
                            <tr>
                              <td align="center" style="width:40px;height:40px;border-radius:50%;font-size:16px;font-weight:800;color:#ffffff;background-color:#3498db;">{{index_1 @index}}</td>
                            </tr>
                          </table>
                        </td>
                        <td style="vertical-align:top;">
                          <h3 class="story-title-text" style="margin:0;font-size:20px;font-weight:700;color:#ffffff;line-height:1.5;">{{title}}</h3>
                        </td>
                      </tr>
                    </table>

                    <!-- Badge 列 -->
                    <table role="presentation" cellpadding="0" cellspacing="0" border="0" style="margin-bottom:20px;">
                      <tr>
                        <td style="padding-right:8px;padding-bottom:6px;">
                          <span style="display:inline-block;padding:3px 10px;border-radius:20px;font-size:11px;font-weight:600;background-color:#3d2e0a;color:#f39c12;">&#9733; 重要度 {{importanceScore}}/10</span>
                        </td>
                        <td style="padding-right:8px;padding-bottom:6px;">
                          <span style="display:inline-block;padding:3px 10px;border-radius:20px;font-size:11px;font-weight:600;background-color:#1a2a3d;color:#5dade2;">
                            {{#if (eq category 'market')}}市場行情{{/if}}
                            {{#if (eq category 'regulation')}}監管政策{{/if}}
                            {{#if (eq category 'technology')}}技術發展{{/if}}
                            {{#if (eq category 'defi')}}DeFi{{/if}}
                            {{#if (eq category 'nft')}}NFT{{/if}}
                            {{#if (eq category 'security')}}安全事件{{/if}}
                            {{#if (eq category 'macro')}}總體經濟{{/if}}
                            {{#if (eq category 'exchange')}}交易所動態{{/if}}
                            {{#if (eq category 'other')}}其他{{/if}}
                          </span>
                        </td>
                        <td style="padding-right:8px;padding-bottom:6px;">
                          <span style="display:inline-block;padding:3px 10px;border-radius:20px;font-size:11px;font-weight:600;
                            {{#if (eq sentiment 'positive')}}background-color:#0e2e1a;color:#2ecc71;{{/if}}
                            {{#if (eq sentiment 'negative')}}background-color:#2e0e0e;color:#e74c3c;{{/if}}
                            {{#if (eq sentiment 'neutral')}}background-color:#1e1e1e;color:#95a5a6;{{/if}}
                          ">
                            {{#if (eq sentiment 'positive')}}&#8679; 正向{{/if}}
                            {{#if (eq sentiment 'negative')}}&#8681; 負向{{/if}}
                            {{#if (eq sentiment 'neutral')}}&#8644; 中性{{/if}}
                          </span>
                        </td>
                        {{#each relatedTickers}}
                        <td style="padding-right:8px;padding-bottom:6px;">
                          <span style="display:inline-block;padding:3px 10px;border-radius:20px;font-size:11px;font-weight:600;background-color:#1e1530;color:#bb8fce;">{{this}}</span>
                        </td>
                        {{/each}}
                      </tr>
                    </table>

                    <!-- AI 摘要 -->
                    {{#if aiSummary}}
                    <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%" style="margin-bottom:16px;">
                      <tr>
                        <td style="background-color:#12121e;border-left:3px solid #e74c3c;border-radius:0 8px 8px 0;padding:24px 28px;">
                          <p style="margin:0 0 10px 0;font-size:10px;font-weight:700;color:#e74c3c;letter-spacing:1.5px;text-transform:uppercase;">AI 摘要</p>
                          <p style="margin:0;font-size:15px;line-height:2;color:#c8c8c8;">{{aiSummary}}</p>
                        </td>
                      </tr>
                    </table>
                    {{/if}}

                    <!-- 來源 + 閱讀原文 -->
                    <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%" style="margin-top:16px;border-collapse:collapse;">
                      <tr>
                        <td style="padding-top:16px;border-top:1px solid #2a2a3e;font-size:12px;color:#7f8fa6;">
                          <strong style="color:#95a5a6;">{{sourceName}}</strong>
                          <span style="margin:0 6px;color:#3d3d5e;">&#183;</span>
                          <span>{{publishedAtFormatted}}（台北時間）</span>
                        </td>
                        <td align="right" style="padding-top:16px;border-top:1px solid #2a2a3e;">
                          <a href="{{url}}" target="_blank" rel="noopener noreferrer" class="read-link"
                             style="font-size:12px;color:#3498db;text-decoration:none;font-weight:600;">閱讀原文 &rarr;</a>
                        </td>
                      </tr>
                    </table>

                  </td>
                </tr>
              </table>
              {{/each}}
              {{/if}}

            </td>
          </tr>
        </table>

        <!-- ═══════════════════════════════════════
             FOOTER
        ═══════════════════════════════════════ -->
        <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%" style="background-color:#1a1a2e;border-top:1px solid #2a2a3e;margin-top:48px;">
          <tr>
            <td align="center" style="padding:32px 24px;">
              <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="820" class="main-table" style="max-width:820px;width:100%;">
                <tr>
                  <td align="center">
                    <p style="margin:0 0 16px 0;font-size:12px;color:#7f8fa6;">
                      <strong style="color:#95a5a6;">資料來源：</strong>{{sourcesText}}
                    </p>
                    <p style="margin:0 0 8px 0;font-size:11px;color:#4a5568;line-height:1.8;">
                      本報告由 AI 自動生成，僅供參考，不構成投資建議。<br />
                      加密貨幣投資具有高度風險，請自行評估並謹慎決策。
                    </p>
                    <p style="margin:12px 0 0 0;font-size:10px;color:#3d4b5c;">
                      &copy; {{reportDate}} Crypto Daily News &nbsp;|&nbsp; Powered by AI
                    </p>
                  </td>
                </tr>
              </table>
            </td>
          </tr>
        </table>

      </td>
    </tr>
  </table>

</body>
</html>
